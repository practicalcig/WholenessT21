<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="AppTheme" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/splashBg</item>
        <item name="android:colorBackground">@color/splashBg</item>
        <item name="android:statusBarColor">@color/splashBg</item>
        <item name="android:navigationBarColor">@color/splashBg</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Same as AppTheme but uses the splash drawable as the initial windowBackground
         so launching the app shows the brand mark instantly while WebView warms up. -->
    <style name="AppTheme.Splash" parent="AppTheme">
        <item name="android:windowBackground">@drawable/splash_screen</item>
    </style>

</resources>
